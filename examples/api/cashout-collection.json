{
  "info": {
    "name": "QIOS — Wallet Cashout Collection",
    "_postman_id": "qios-cashout-example",
    "description": "Complete example collection generated by QIOS api-spec-generator",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://api.dev.com", "type": "string" },
    { "key": "token",    "value": "",                     "type": "string" }
  ],
  "item": [
    {
      "name": "Cashout — Happy Path",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200', () => pm.response.to.have.status(200));",
        "pm.test('Response < 2000ms', () => pm.expect(pm.response.responseTime).to.be.below(2000));",
        "pm.test('Has transaction_id', () => { pm.expect(pm.response.json()).to.have.property('transaction_id'); });",
        "pm.test('Has status field', () => { pm.expect(pm.response.json()).to.have.property('status'); });"
      ]}}],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type",  "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/wallet/cashout" },
        "body": { "mode": "raw", "raw": "{\"amount\": 100, \"currency\": \"USD\", \"recipient_id\": \"usr_123\"}" }
      }
    },
    {
      "name": "Cashout — Missing amount (negative)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 400', () => pm.response.to.have.status(400));",
        "pm.test('Has error message', () => { pm.expect(pm.response.json()).to.have.property('error'); });"
      ]}}],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type",  "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/wallet/cashout" },
        "body": { "mode": "raw", "raw": "{\"currency\": \"USD\", \"recipient_id\": \"usr_123\"}" }
      }
    },
    {
      "name": "Cashout — No auth token (negative)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 401', () => pm.response.to.have.status(401));"
      ]}}],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/wallet/cashout" },
        "body": { "mode": "raw", "raw": "{\"amount\": 100, \"currency\": \"USD\", \"recipient_id\": \"usr_123\"}" }
      }
    },
    {
      "name": "Cashout — Negative amount (boundary)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 400', () => pm.response.to.have.status(400));",
        "pm.test('Validation error', () => { pm.expect(pm.response.json()).to.have.property('error'); });"
      ]}}],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type",  "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/wallet/cashout" },
        "body": { "mode": "raw", "raw": "{\"amount\": -50, \"currency\": \"USD\", \"recipient_id\": \"usr_123\"}" }
      }
    },
    {
      "name": "Cashout — SQL injection (security)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 400', () => pm.response.to.have.status(400));",
        "pm.test('No DB error exposed', () => {",
        "  const text = pm.response.text();",
        "  pm.expect(text).to.not.include('SQL');",
        "  pm.expect(text).to.not.include('syntax error');",
        "});"
      ]}}],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type",  "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/wallet/cashout" },
        "body": { "mode": "raw", "raw": "{\"amount\": 100, \"currency\": \"USD\", \"recipient_id\": \"' OR '1'='1\"}" }
      }
    }
  ]
}
