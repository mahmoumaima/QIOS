          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Response < 2000ms', () => pm.expect(pm.response.responseTime).to.be.below(2000));",
                "pm.test('Content-Type is JSON', () => {",
                "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                "});",
                "pm.test('Has transaction_id', () => {",
                "  const body = pm.response.json();",
                "  pm.expect(body).to.have.property('transaction_id');",
                "  pm.expect(body.transaction_id).to.be.a('string');",
                "});",
                "pm.test('Has status field', () => {",
                "  const body = pm.response.json();",
                "  pm.expect(body).to.have.property('status');",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/wallet/cashout",
              "host": ["{{base_url}}"],
              "path": ["wallet", "cashout"]
            },
